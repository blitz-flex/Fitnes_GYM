#: src/templates/main/partials/about_services.html:60
msgid "24/7 Access"
msgstr "24/7 წვდომა"

#: src/templates/main/partials/about_services.html:61
msgid ""
"Complete flexibility - the center is open 24 hours a day, 7 days a week. "
"A modern security system ensures safety."
msgstr "სრული მოქნილობა - ცენტრი ღიაა 24 საათი, კვირაში 7 დღე."

#: src/templates/main/partials/about_team.html:5
